# Environment / secrets
.env
# NSFW rule lists — kept out of source; see nsfw_rules.example.json for the schema
/nsfw_rules.json

# Local data — NEVER commit (years of personal content from many accounts)
data/
exports/
*.db
*.db-shm
*.db-wal
*.sqlite

# Source exports / dumps
takeout*/
*Takeout*.zip
*.ndjson
saved*.json
saved*.csv

# Python
.venv/
__pycache__/
*.pyc
*.egg-info/
dist/
build/
.pytest_cache/
.pytest-tmp/
.pytest-review-tmp/
.pytest-*-tmp/
.mypy_cache/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
.continue/

# Local preview-server config (machine-specific absolute paths)
.claude/launch.json

# Ephemeral worktrees created by scripts/serve_branch_verify.py (auto-cleaned)
.verify-worktrees/

# Local MCP server picks (machine-specific; brave-search reads an ambient BRAVE_API_KEY)
.mcp.json

# Autonomous-run tracking artifacts (charter, progress, report — not product source)
.autonomous/

# Design-system reference bundle (vendored separately into static/; not product source)
design-ref/

# Allow only the tiny curated synthetic test fixtures
!fixtures/
!fixtures/**
