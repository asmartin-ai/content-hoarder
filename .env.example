# Copy to .env and adjust. .env is gitignored — never commit it.

# Database path (relative to CWD; run from the project root, or set an absolute path)
CONTENT_HOARDER_DB=data/app.db

# Web server
CONTENT_HOARDER_HOST=127.0.0.1
CONTENT_HOARDER_PORT=8788
FLASK_SECRET_KEY=change-me-to-something-random
# Extra hostnames the CSRF/rebinding guard accepts (comma-separated). Localhost, private
# LAN IPs, Tailscale (100.64/10) and *.ts.net are always allowed — set only for real DNS.
CONTENT_HOARDER_ALLOWED_HOSTS=
USER_AGENT=content-hoarder/0.1 (local personal use)

# Reddit cookie transport blends in better with a real browser UA than the generic one
# above. Best: paste YOUR actual browser's User-Agent here (Firefox: about:support →
# "User Agent"; any browser: navigator.userAgent in the dev-tools console).
REDDIT_BROWSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:140.0) Gecko/20100101 Firefox/140.0

# Reddit OAuth (installed-app, read-only "read" scope) — the sanctioned, lower-risk
# hydration transport. Reuse a PUBLIC installed-app client id (e.g. RedReader's); there is
# NO client secret. The redirect URI must match that app's registered one.
# Run `python -m content_hoarder reddit-oauth login` once to authorize; the refresh token is
# then stored in the local DB (never the repo). Leave CLIENT_ID blank to stay cookie-only.
REDDIT_OAUTH_CLIENT_ID=
REDDIT_OAUTH_REDIRECT_URI=redreader://rr_oauth_redir

# Optional — Karakeep bridge (leave blank to disable). Use a STOCK self-hosted instance.
KARAKEEP_BASE_URL=
KARAKEEP_API_KEY=

# Optional — local LLM assist (LM Studio / Ollama, OpenAI-compatible endpoint)
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_MODEL=
